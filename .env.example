# ============================================
#  🐟 FishPool 环境变量配置
# ============================================
#  复制为 .env 文件后按需修改
#  环境变量优先级高于 config.yaml
# ============================================

# ── Bot 配置 ──
FISHPOOL_BOT_NAME=FishPool
FISHPOOL_BOT_LOG_LEVEL=INFO

# ── QQ 适配器（OneBot v11 旧方案）──
FISHPOOL_ADAPTERS_QQ_ENABLED=true
FISHPOOL_ADAPTERS_QQ_WS_URL=ws://localhost:8080/ws
FISHPOOL_ADAPTERS_QQ_BOT_QQ=123456789
FISHPOOL_ADAPTERS_QQ_RECONNECT_INTERVAL=5
FISHPOOL_ADAPTERS_QQ_MAX_RECONNECT_RETRIES=-1

# ── QQ 官方机器人 API（推荐）──
# 说明：在 https://q.qq.com/ 创建应用后获取以下凭证
FISHPOOL_ADAPTERS_QQ_OFFICIAL_ENABLED=false
FISHPOOL_ADAPTERS_QQ_OFFICIAL_MODE=websocket
FISHPOOL_ADAPTERS_QQ_OFFICIAL_APP_ID=
FISHPOOL_ADAPTERS_QQ_OFFICIAL_APP_SECRET=
FISHPOOL_ADAPTERS_QQ_OFFICIAL_TOKEN=
FISHPOOL_ADAPTERS_QQ_OFFICIAL_SANDBOX=true
FISHPOOL_ADAPTERS_QQ_OFFICIAL_RECONNECT_INTERVAL=5
FISHPOOL_ADAPTERS_QQ_OFFICIAL_MAX_RECONNECT_RETRIES=-1

# ── 微信适配器 ──
FISHPOOL_ADAPTERS_WECHAT_ENABLED=false
FISHPOOL_ADAPTERS_WECHAT_PROTOCOL=wcf
FISHPOOL_ADAPTERS_WECHAT_HOST=127.0.0.1
FISHPOOL_ADAPTERS_WECHAT_PORT=10086
FISHPOOL_ADAPTERS_WECHAT_POLL_INTERVAL=1.0
